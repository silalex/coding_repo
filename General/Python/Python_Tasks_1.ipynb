   "source": [
    "# Strings\n",
    "### 1. Find the first unique character in a string"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "26d8b704",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "'d'"
      ]
     },
     "execution_count": 2,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "def find_first_unique(s: str) -> str:\n",
    "    for c in s:\n",
    "        if s.index(c) == s.rindex(c):\n",
    "            return c\n",
    "        \n",
    "# Test case\n",
    "s = 'adsbfknlam'\n",
    "find_first_unique(s) # Output: 'd'"
   ]
  },
