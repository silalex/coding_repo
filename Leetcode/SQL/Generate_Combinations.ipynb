   "source": [
    "from itertools import combinations\n",
    "\n",
    "numbers = [1, 5, 7, 10, 12, 18, 21]\n",
    "\n",
    "# generate all combinations of 5 numbers\n",
    "combos = list(combinations(numbers, 5))\n",
    "\n",
    "for c in combos:\n",
    "    print(c)\n",
    "\n",
    "print(\"Total combinations:\", len(combos))"
   ]
